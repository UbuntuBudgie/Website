<section class="py-20 lg:py-32">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      
      <!-- Main Header: "Contact us" -->
      <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight text-center text-base-900 mb-16">
        Contact us
      </h1>

      <div class="max-w-7xl mx-auto grid lg:grid-cols-3 gap-12 lg:gap-16">

        <!-- LEFT COLUMN: Message Text Area (2/3 width) -->
        <div class="lg:col-span-2">
          
          <h2 class="text-3xl font-bold tracking-tight text-base-900">
            Send us a message
          </h2>
          
          <!-- Discourse Explanation Text Block -->
          <div class="mt-4 space-y-4 text-base leading-relaxed text-base-600">
            <p>
              We have one on-demand support route - Discourse.
            </p>
            <p>
              Once you register account, you will be able to participate in 
              discussion and ask questions regarding the problem or issue you 
              have, but also to answer questions from other users.
            </p>
          </div>

          <!-- Horizontal Separator -->
          <div class="mt-8 pt-8 border-t border-base-200"></div>
          
          <!-- Note Text Block -->
          <p class="mt-8 text-sm text-base-900 leading-relaxed">
            <span class="font-bold">Note:</span> The following form is 
            <span class="font-bold">NOT for support</span>. We welcome contact 
            from everyone who wishes to get involved with Ubuntu Budgie, 
            regarding press releases or partnership requests or to express 
            interest in joining Ubuntu Budgie team.
          </p>

        </div>

        <!-- RIGHT COLUMN: Discourse Support Box -->
        <div class="lg:col-span-1 h-fit">
          <div style="
            background: #1a1f2e;
            border-radius: 20px;
            padding: 2rem 1.75rem;
            border: 1px solid rgba(255,255,255,0.06);
            box-shadow: 0 8px 32px rgba(0,0,0,0.18);
            display: flex;
            flex-direction: column;
            gap: 1.1rem;
          ">

            <!-- Discourse logo row -->
            <div style="display: flex; align-items: center; gap: 0.75rem;">
              <svg width="36" height="36" viewBox="0 0 38 38" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <rect width="38" height="38" rx="8" fill="#231F20"/>
                <path d="M19.08 7C12.395 7 7 12.373 7 19.031c0 3.535 1.518 6.714 3.944 8.938l-1.09 3.78a.4.4 0 0 0 .536.476l4.064-1.735A12.082 12.082 0 0 0 19.08 31.06C25.765 31.06 31 25.69 31 19.031 31 12.373 25.765 7 19.08 7Z" fill="url(#dg2)"/>
                <defs>
                  <linearGradient id="dg2" x1="7" y1="7" x2="31" y2="31" gradientUnits="userSpaceOnUse">
                    <stop stop-color="#00AEEF"/>
                    <stop offset="0.5" stop-color="#00A94F"/>
                    <stop offset="1" stop-color="#F15D22"/>
                  </linearGradient>
                </defs>
              </svg>
              <span style="font-size: 1.1rem; font-weight: 700; color: #ffffff; letter-spacing: -0.01em;">Discourse</span>
            </div>

            <!-- Divider -->
            <div style="height: 1px; background: rgba(255,255,255,0.08);"></div>

            <!-- Text -->
            <p style="font-size: 0.875rem; color: rgba(255,255,255,0.62); line-height: 1.7; margin: 0;">
              <strong style="color: #ffffff; font-weight: 600;">Need help?</strong> To receive support, visit our community forum. Register an account to ask questions, report issues and get answers from our community.
            </p>

            <!-- Button -->
            <a
              href="https://discourse.ubuntubudgie.org"
              target="_blank"
              rel="noopener noreferrer"
              style="
                display: inline-flex;
                align-items: center;
                gap: 0.45rem;
                padding: 0.65rem 1.25rem;
                border-radius: 980px;
                font-size: 0.875rem;
                font-weight: 600;
                color: #ffffff;
                background: #0071e3;
                text-decoration: none;
                letter-spacing: -0.01em;
                transition: background 0.18s;
                width: fit-content;
              "
              onmouseover="this.style.background='#0080f5'"
              onmouseout="this.style.background='#0071e3'"
            >
              Go to Support Forum
              <svg width="12" height="12" viewBox="0 0 13 13" fill="none" aria-hidden="true">
                <path d="M2.5 10.5l8-8M10.5 2.5H5M10.5 2.5v5.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>

          </div>
        </div>
      </div>
    </div>
  </section>