---

import type { CollectionEntry } from "astro:content";

const { post, author } = Astro.props as {
  post: CollectionEntry<"blog">;
  author: CollectionEntry<"authors"> | CollectionEntry<"team">;
};

const { id } = post;
const cleanSlug = id.split('/').pop()?.replace(/^\d{4}-\d{2}-\d{2}-/, '') || id;
// 1. Extract image as 'rawImage'
const { title, description, pubDate, image: rawImage, category: rawCategory, tags } = post.data;

// 2. Bulletproof path fixer
function fixImagePath(path?: string) {
  if (!path) return undefined;
  return (path.startsWith('/') ? path : `/${path}`).replace(/^\/public/, '');
}

// 3. Fix main image
const image = fixImagePath(rawImage);

const category = rawCategory || (tags && tags.length > 0 ? tags[0] : undefined);

const authorName = author.data.name;

let rawAuthorImage = "";
if (author.collection === "authors") {
  rawAuthorImage = author.data.image || "";
} else if (author.collection === "team") {
  rawAuthorImage = author.data.avatar?.src || "";
}

// 4. Fix author image
const fixedAuthorImage = fixImagePath(rawAuthorImage);
---

<style>
  .pc {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border-radius: 20px;
    background: #ffffff;
    border: 1px solid rgba(0,0,0,0.07);
    transition: transform 0.28s cubic-bezier(0.22,1,0.36,1),
                box-shadow 0.28s cubic-bezier(0.22,1,0.36,1);
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Ubuntu, Cantarell, sans-serif;
  }

  .pc:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 48px rgba(0,0,0,0.11);
  }

  /* ── Image ── */
  .pc-img-wrap {
    display: block;
    aspect-ratio: 16/9;
    overflow: hidden;
    flex-shrink: 0;
  }

  .pc-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s cubic-bezier(0.22,1,0.36,1);
  }

  .pc:hover .pc-img-wrap img { transform: scale(1.04); }

  /* ── Body ── */
  .pc-body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 1.4rem 1.5rem 1.35rem;
  }

  /* ── Category pill ── */
  .pc-cat {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #0071e3;
    background: rgba(0,113,227,0.08);
    border-radius: 999px;
    padding: 0.28rem 0.7rem;
    margin-bottom: 0.85rem;
    width: fit-content;
  }

  /* ── Title ── */
  .pc-title {
    font-size: 1.15rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.3;
    color: #1d1d1f;
    text-decoration: none;
    display: block;
    margin-bottom: 0.6rem;
    transition: color 0.15s;
  }

  .pc-title:hover { color: #0071e3; }

  /* ── Description ── */
  .pc-desc {
    font-size: 0.875rem;
    color: #6e6e73;
    line-height: 1.65;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Footer ── */
  .pc-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-top: auto;
    padding-top: 1.1rem;
    border-top: 1px solid rgba(0,0,0,0.06);
    margin-top: 1.25rem;
  }

  .pc-author {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    min-width: 0;
  }

  .pc-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
    border: 1.5px solid rgba(0,0,0,0.08);
  }

  .pc-author-info {
    display: flex;
    flex-direction: column;
    gap: 1px;
    min-width: 0;
  }

  .pc-author-name {
    font-size: 0.8rem;
    font-weight: 600;
    color: #1d1d1f;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .pc-date {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.72rem;
    color: #86868b;
  }

  /* ── Read more link ── */
  .pc-read {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.78rem;
    font-weight: 600;
    color: #0071e3;
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    transition: gap 0.18s ease;
  }

  .pc-read:hover { gap: 0.4rem; }
</style>

<article class="pc">

  {image && (
    <a href={`/blog/${cleanSlug}/`} class="pc-img-wrap" aria-label={`Read: ${title}`}>
      <img src={image} alt={title} />
    </a>
  )}

  <div class="pc-body">

    {category && (
      <span class="pc-cat">
        <!-- tag icon -->
        <svg width="9" height="9" viewBox="0 0 12 12" fill="none" aria-hidden="true">
          <path d="M1 1h4.5L11 6.5 6.5 11 1 5.5V1z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
          <circle cx="3.5" cy="3.5" r="0.75" fill="currentColor"/>
        </svg>
        {category}
      </span>
    )}

    <a href={`/blog/${cleanSlug}/`} class="pc-title">{title}</a>
    <p class="pc-desc">{description}</p>

    <footer class="pc-footer">
      <div class="pc-author">
        {fixedAuthorImage && (
          <img src={fixedAuthorImage} alt={authorName} class="pc-avatar" />
        )}
        <div class="pc-author-info">
          <span class="pc-author-name">{authorName}</span>
          <time datetime={pubDate.toISOString()} class="pc-date">
            <!-- calendar icon -->
            <svg width="10" height="10" viewBox="0 0 12 12" fill="none" aria-hidden="true">
              <rect x="1" y="2" width="10" height="9" rx="1.5" stroke="currentColor" stroke-width="1.2"/>
              <path d="M1 5h10" stroke="currentColor" stroke-width="1.2"/>
              <path d="M4 1v2M8 1v2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
            </svg>
            {pubDate.toLocaleDateString(undefined, { month: "short", day: "numeric", year: "numeric" })}
          </time>
        </div>
      </div>

      <a href={`/blog/${cleanSlug}/`} class="pc-read" aria-label={`Read ${title}`}>
        Read
        <!-- arrow icon -->
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
          <path d="M2 6h8M7 3l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </footer>

  </div>
</article>