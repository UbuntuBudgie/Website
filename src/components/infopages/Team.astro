---

<style>
  .tm {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Ubuntu, Cantarell, sans-serif;
    color: #1d1d1f;
  }

  /* ── HEADER ──────────────────────────────────────────────── */
  .tm-header {
    text-align: center;
    padding: 5rem 1.5rem 4rem;
    position: relative;
  }

  .tm-header::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 65% 55% at 50% 0%,
      rgba(0,113,227,0.05) 0%, transparent 70%);
    pointer-events: none;
  }

  .tm-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #0071e3;
    background: rgba(0,113,227,0.08);
    border-radius: 999px;
    padding: 0.28rem 0.85rem;
    margin-bottom: 1.25rem;
    position: relative;
    z-index: 1;
  }

  .tm-header h1 {
    font-size: clamp(2.5rem, 5.5vw, 4rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1.07;
    color: #1d1d1f;
    margin: 0 auto 1.1rem;
    max-width: 700px;
    position: relative;
    z-index: 1;
  }

  .tm-header p {
    font-size: clamp(1rem, 1.8vw, 1.1rem);
    color: #6e6e73;
    line-height: 1.75;
    max-width: 520px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  /* ── TEAM GRID ───────────────────────────────────────────── */
  .tm-grid-wrap {
    background: #f5f5f7;
    padding: 1rem 1rem 5rem;
  }

  .tm-grid-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .tm-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1rem;
  }

  @media (max-width: 1100px) { .tm-grid { grid-template-columns: repeat(4, 1fr); } }
  @media (max-width: 800px)  { .tm-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 540px)  { .tm-grid { grid-template-columns: repeat(2, 1fr); } }

  /* ── APPLE-STYLE CARD ────────────────────────────────────── */
  .tm-card {
    background: #ffffff;
    border-radius: 20px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.3s cubic-bezier(0.22,1,0.36,1),
                box-shadow  0.3s cubic-bezier(0.22,1,0.36,1);
    cursor: default;
  }

  .tm-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 48px rgba(0,0,0,0.11);
  }

  /* Photo fills the top — no padding, edge to edge */
  .tm-avatar-wrap {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    flex-shrink: 0;
    background: #e8e8ed;
  }

  .tm-avatar-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    transition: transform 0.4s cubic-bezier(0.22,1,0.36,1);
  }

  .tm-card:hover .tm-avatar-wrap img {
    transform: scale(1.04);
  }

  /* Text block */
  .tm-card-body {
    padding: 1rem 1.1rem 1.1rem;
    border-top: 1px solid rgba(0,0,0,0.06);
    display: flex;
    flex-direction: column;
    gap: 0;
    flex: 1;
  }

  .tm-name {
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: -0.015em;
    color: #1d1d1f;
    line-height: 1.3;
    margin: 0 0 0.2rem;
  }

  .tm-role {
    font-size: 0.72rem;
    font-weight: 500;
    color: #6e6e73;
    line-height: 1.4;
    margin: 0 0 0.85rem;
  }

  /* Social icon row */
  .tm-socials {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding-top: 0.7rem;
    border-top: 1px solid rgba(0,0,0,0.06);
    margin-top: auto;
  }

  .tm-social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 7px;
    background: rgba(0,0,0,0.05);
    text-decoration: none;
    transition: background 0.15s, opacity 0.15s;
    flex-shrink: 0;
  }

  .tm-social-link:hover { opacity: 0.75; }

  /* Brand colours */
  .tm-social-link.x-link     { color: #000000; }
  .tm-social-link.m-link     { color: #6364FF; }
  .tm-social-link.gh-link    { color: #24292e; }

  .tm-social-link.x-link:hover  { background: rgba(0,0,0,0.10); }
  .tm-social-link.m-link:hover  { background: rgba(99,100,255,0.12); }
  .tm-social-link.gh-link:hover { background: rgba(36,41,46,0.10); }

  .tm-social-link svg {
    width: 13px;
    height: 13px;
    display: block;
    flex-shrink: 0;
  }

  .tm-social-sep {
    display: none; /* no longer needed with icon-only layout */
  }

  /* ── ALUMNI ──────────────────────────────────────────────── */
  .tm-alumni {
    background: #f5f5f7;
    border-top: 1px solid rgba(0,0,0,0.07);
    border-bottom: 1px solid rgba(0,0,0,0.07);
    padding: 4rem 1.5rem;
  }

  .tm-alumni-inner {
    max-width: 860px;
    margin: 0 auto;
  }

  .tm-alumni-header {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 1.75rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid rgba(0,0,0,0.08);
  }

  .tm-alumni-header h2 {
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: #1d1d1f;
    margin: 0;
    line-height: 1;
  }

  .tm-alumni-header span {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #c7c7cc;
  }

  .tm-alumni-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .tm-alumni-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.85rem 0;
    border-bottom: 1px solid rgba(0,0,0,0.05);
    font-size: 0.9rem;
    color: #3a3a3c;
    line-height: 1.5;
  }

  .tm-alumni-item:last-child { border-bottom: none; }

  .tm-alumni-item::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #c7c7cc;
    flex-shrink: 0;
  }

  .tm-alumni-item a {
    color: #0071e3;
    text-decoration: none;
    font-weight: 500;
  }

  .tm-alumni-item a:hover { text-decoration: underline; }

  .tm-alumni-item em {
    font-size: 0.78rem;
    color: #86868b;
    font-style: normal;
    margin-left: 0.3rem;
  }

  /* ── CTA ─────────────────────────────────────────────────── */
  .tm-cta {
    padding: 5rem 1.5rem;
    text-align: center;
  }

  .tm-cta-inner {
    max-width: 540px;
    margin: 0 auto;
    background: #f5f5f7;
    border-radius: 24px;
    padding: 3rem 2.5rem;
    border: 1px solid rgba(0,0,0,0.07);
  }

  .tm-cta-icon {
    width: 52px;
    height: 52px;
    border-radius: 14px;
    background: rgba(0,113,227,0.09);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #0071e3;
    margin: 0 auto 1.5rem;
  }

  .tm-cta-icon svg { width: 24px; height: 24px; }

  .tm-cta h3 {
    font-size: clamp(1.4rem, 2.5vw, 1.9rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: #1d1d1f;
    margin: 0 0 0.75rem;
    line-height: 1.15;
  }

  .tm-cta p {
    font-size: 0.925rem;
    color: #6e6e73;
    line-height: 1.75;
    margin: 0 0 1.75rem;
  }

  .tm-cta a {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.8rem 1.75rem;
    border-radius: 980px;
    font-size: 0.9rem;
    font-weight: 600;
    color: #fff;
    background: #0071e3;
    text-decoration: none;
    letter-spacing: -0.01em;
    transition: background 0.18s, transform 0.18s;
  }

  .tm-cta a:hover { background: #0080f5; transform: scale(1.02); }

  /* ── FADE-IN ─────────────────────────────────────────────── */
  @keyframes tmFadeUp {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .tm-anim { opacity: 0; }
  .tm-anim.visible { animation: tmFadeUp 0.6s cubic-bezier(0.22,1,0.36,1) both; }
  .tm-anim.d1.visible { animation-delay: 0.04s; }
  .tm-anim.d2.visible { animation-delay: 0.10s; }
  .tm-anim.d3.visible { animation-delay: 0.16s; }
  .tm-anim.d4.visible { animation-delay: 0.22s; }
  .tm-anim.d5.visible { animation-delay: 0.28s; }
</style>

<div class="tm">

  <!-- ── HEADER ────────────────────────────────────────────── -->
  <div class="tm-header tm-anim">
    <span class="tm-eyebrow">
      <svg width="10" height="10" viewBox="0 0 12 12" fill="none" aria-hidden="true">
        <circle cx="4" cy="3.5" r="1.8" stroke="currentColor" stroke-width="1.3"/>
        <circle cx="8.5" cy="3.5" r="1.8" stroke="currentColor" stroke-width="1.3"/>
        <path d="M1 10.5c0-1.93 1.34-3 3-3s3 1.07 3 3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
        <path d="M8 8c.6-.3 1.4-.3 2 .3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
      </svg>
      The Ubuntu Budgie Family
    </span>
    <h1>Meet Our Team<br/>of Volunteers</h1>
    <p>A single, passionate team from all around the world who contribute to every aspect of the project.</p>
  </div>

  <!-- ── TEAM GRID ──────────────────────────────────────────── -->
  <div class="tm-grid-wrap">
    <div class="tm-grid-inner">
      <div class="tm-grid">
        {teamMembers.map((member, i) => (
          <div class={`tm-card tm-anim d${(i % 5) + 1}`}>

            <div class="tm-avatar-wrap">
              <img
                src={member.image || '/avatars/placeholder.jpg'}
                alt={`Photo of ${member.name}`}
                width="240"
                height="240"
                loading="lazy"
              />
            </div>

            <div class="tm-card-body">
              <h3 class="tm-name">{member.name}</h3>
              <p class="tm-role">{member.role}</p>

              {(member.twitter || member.mastodon || member.github) && (
                <div class="tm-socials">
                  {member.twitter && (
                    <a href={`https://x.com/${member.twitter}`} target="_blank" rel="noopener noreferrer" class="tm-social-link x-link" aria-label="X / Twitter">
                      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.901 1.144h3.68l-8.623 9.878 10.368 12.878h-8.136l-6.621-8.23-8.083 8.23h-3.676l9.648-10.975-10.518-12.031h8.225l5.372 6.136L18.901 1.144Zm-1.523 18.52h3.047L6.89 4.145H3.844L17.378 19.664Z"/></svg>
                    </a>
                  )}
                  {member.mastodon && (
                    <a href={`https://mastodon.social/@${member.mastodon}`} target="_blank" rel="noopener noreferrer" class="tm-social-link m-link" aria-label="Mastodon">
                      <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M11.19 12.195c2.016-.24 3.77-1.475 3.99-2.603.348-1.778.32-4.339.32-4.339 0-3.47-2.286-4.488-2.286-4.488C12.062.238 10.083.017 8.027 0h-.05C5.92.017 3.942.238 2.79.765c0 0-2.285 1.017-2.285 4.488l-.002.662c-.004.64-.007 1.35.011 2.091.083 3.394.626 6.74 3.78 7.57 1.454.383 2.703.463 3.709.408 1.823-.1 2.847-.647 2.847-.647l-.06-1.317s-1.303.41-2.767.36c-1.45-.05-2.98-.156-3.215-1.928a4 4 0 0 1-.033-.496s1.424.346 3.228.428c1.103.05 2.137-.064 3.188-.189zm1.613-2.47H11.13v-4.08c0-.859-.364-1.295-1.091-1.295-.804 0-1.207.517-1.207 1.541v2.233H7.168V5.89c0-1.024-.403-1.541-1.207-1.541-.727 0-1.091.436-1.091 1.296v4.079H3.197V5.522q0-1.288.66-2.046c.456-.505 1.052-.764 1.793-.764.856 0 1.504.328 1.933.983L8 4.39l.417-.695c.429-.655 1.077-.983 1.934-.983.74 0 1.336.259 1.791.764q.662.757.661 2.046z"/></svg>
                    </a>
                  )}
                  {member.github && (
                    <a href={`https://github.com/${member.github}`} target="_blank" rel="noopener noreferrer" class="tm-social-link gh-link" aria-label="GitHub">
                      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.6.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222 0 1.606-.015 2.898-.015 3.293 0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
                    </a>
                  )}
                </div>
              )}
            </div>

          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- ── ALUMNI ─────────────────────────────────────────────── -->
  <div class="tm-alumni">
    <div class="tm-alumni-inner tm-anim">
      <div class="tm-alumni-header">
        <h2>Alumni</h2>
        <span>Past contributors</span>
      </div>
      <div class="tm-alumni-list">
        <div class="tm-alumni-item">NIYAS C — Developer</div>
        <div class="tm-alumni-item">
          <a href="https://github.com/HEXcube" target="_blank" rel="noopener noreferrer">Rohan "HEXcube" Villoth</a> — Designer and Developer
        </div>
        <div class="tm-alumni-item">JOSHUA "FOGGALONG" FOGG — Developer</div>
        <div class="tm-alumni-item">VINCENZO BOVINO — Brand and PR Manager</div>
        <div class="tm-alumni-item">EFKAN ISAZADE — Project Manager</div>
        <div class="tm-alumni-item">Serdar — Budgie Applet Developer</div>
        <div class="tm-alumni-item">
          Lipe Forman — Project Manager and Representative of Brazilian community
          <em>· In memoriam</em>
        </div>
      </div>
    </div>
  </div>

  <!-- ── CTA ───────────────────────────────────────────────── -->
  <div class="tm-cta">
    <div class="tm-cta-inner tm-anim">
      <div class="tm-cta-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
          <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
        </svg>
      </div>
      <h3>Want to join the team?</h3>
      <p>The Ubuntu Budgie project is always welcoming new contributors — from coding and bug triage to documentation and community support.</p>
      <a href="https://discourse.ubuntubudgie.org/t/get-involved/64" target="_blank" rel="noopener noreferrer">
        Discover How to Contribute
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
          <path d="M2.5 9.5l7-7M9.5 2.5H5M9.5 2.5v4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>

</div>

<script>
  (function () {
    var els = document.querySelectorAll('.tm-anim');
    if (!els.length) return;
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.08 });
    els.forEach(function (el) { io.observe(el); });
  })();
</script>