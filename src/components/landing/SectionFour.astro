<style>
  .s4 {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Ubuntu, Cantarell, sans-serif;
  }

  /* ── APPLETS SECTION ─────────────────────────────────────── */
  .s4-applets {
    background: #f5f5f7;
    padding: 6rem 1.5rem 5rem;
  }

  .s4-applets-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .s4-applets-header .eyebrow {
    display: inline-block;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #0071e3;
    margin-bottom: 0.75rem;
  }

  .s4-applets-header h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: #1d1d1f;
    margin: 0 0 0.75rem;
    line-height: 1.1;
  }

  .s4-applets-header p {
    font-size: 1.05rem;
    color: #6e6e73;
    max-width: 520px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* ── BENTO GRID ──────────────────────────────────────────── */
  .s4-bento {
    display: grid;
    grid-template-columns: repeat(8, 1fr);
    gap: 1rem;
    max-width: 1600px;
    margin: 0 auto;
  }

  @media (max-width: 1024px) { .s4-bento { grid-template-columns: repeat(4, 1fr); } }
  @media (max-width: 680px)  { .s4-bento { grid-template-columns: repeat(2, 1fr); } }

  .s4-bc {
    background: #fff;
    border-radius: 20px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.3s cubic-bezier(0.22,1,0.36,1),
                box-shadow 0.3s cubic-bezier(0.22,1,0.36,1);
  }

  .s4-bc:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 48px rgba(0,0,0,0.10);
  }

  .s4-bc-2 { grid-column: span 2; }
  .s4-bc-3 { grid-column: span 3; }
  .s4-bc-4 { grid-column: span 4; }

  @media (max-width: 1024px) {
    .s4-bc-3 { grid-column: span 2; }
    .s4-bc-4 { grid-column: span 4; }
  }
  @media (max-width: 680px) {
    .s4-bc-2, .s4-bc-3, .s4-bc-4 { grid-column: span 2; }
  }

  .s4-bc-img {
    width: 100%;
    flex: 1;
    min-height: 160px;
    max-height: 240px;
    object-fit: cover;
    display: block;
  }

  .s4-bc-3 .s4-bc-img,
  .s4-bc-4 .s4-bc-img { max-height: 280px; }

  .s4-bc-body {
    padding: 1.1rem 1.25rem 1.25rem;
    border-top: 1px solid rgba(0,0,0,0.06);
    flex-shrink: 0;
  }

  .s4-bc-body h3 {
    font-size: 1.45rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: #1d1d1f;
    margin: 0 0 0.35rem;
  }

  .s4-bc-body p {
    font-size: 0.95rem;
    color: #6e6e73;
    line-height: 1.6;
    margin: 0;
  }

  .s4-applets-cta {
    text-align: center;
    margin-top: 2.5rem;
  }

  .s4-applets-cta a {
    display: inline-block;
    background: #0071e3;
    color: #fff;
    font-size: 1.25rem;
    font-weight: 500;
    padding: 0.8rem 2rem;
    border-radius: 980px;
    text-decoration: none;
    transition: background 0.2s, transform 0.2s;
  }

  .s4-applets-cta a:hover { background: #0077ed; transform: scale(1.02); }

  /* ── TESTIMONIALS ────────────────────────────────────────── */
  .s4-testimonials {
    background: #f5f5f7;
    padding: 7rem 1.5rem;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Ubuntu, Cantarell, sans-serif;
  }

  .s4-t-inner {
    max-width: 1120px;
    margin: 0 auto;
  }

  .s4-t-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: 4rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid rgba(0,0,0,0.08);
  }

  @media (max-width: 700px) {
    .s4-t-header { flex-direction: column; align-items: flex-start; }
  }

  .s4-t-eyebrow {
    display: block;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #6e6e73;
    margin-bottom: 0.6rem;
  }

  .s4-t-title {
    font-size: clamp(2.25rem, 4vw, 3.25rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.08;
    color: #1d1d1f;
    margin: 0;
  }

  .s4-t-sub {
    font-size: 0.95rem;
    color: #86868b;
    line-height: 1.7;
    max-width: 320px;
    text-align: right;
    margin: 0;
  }

  @media (max-width: 700px) {
    .s4-t-sub { text-align: left; max-width: 100%; }
  }

  /* Grid */
  .s4-t-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: rgba(0,0,0,0.07);
    border-radius: 22px;
    overflow: hidden;
  }

  @media (max-width: 700px) { .s4-t-grid { grid-template-columns: 1fr; } }

  /* Card */
  .s4-t-card {
    background: #ffffff;
    padding: 2.75rem 2.5rem 2.25rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 2rem;
    transition: background 0.25s ease;
  }

  .s4-t-card:hover { background: #fafafa; }

  /* Opening mark */
  .s4-t-quote {
    font-size: clamp(1rem, 1.4vw, 1.1rem);
    color: #1d1d1f;
    line-height: 1.75;
    margin: 0;
    font-weight: 300;
    position: relative;
    padding-top: 2.25rem;
  }

  .s4-t-quote::before {
    content: '\201C';
    position: absolute;
    top: 0; left: -4px;
    font-size: 3.5rem;
    line-height: 1;
    color: #d2d2d7;
    font-family: Georgia, serif;
    font-weight: 400;
  }

  /* Footer row */
  .s4-t-footer {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(0,0,0,0.07);
  }

  .s4-t-avatar {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
    border: 1px solid rgba(0,0,0,0.08);
  }

  .s4-t-person {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
  }

  .s4-t-name {
    font-size: 0.875rem;
    font-weight: 600;
    color: #1d1d1f;
    letter-spacing: -0.01em;
  }

  .s4-t-role {
    font-size: 0.775rem;
    color: #86868b;
  }

  .s4-t-pub {
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #c7c7cc;
  }

  /* ── SPONSORS ─────────────────────────────────────────────── */
  .s4-sponsors {
    background: #ffffff;
    padding: 7rem 1.5rem;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Ubuntu, Cantarell, sans-serif;
  }

  .s4-sp-inner {
    max-width: 1120px;
    margin: 0 auto;
  }

  .s4-sp-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .s4-sp-eyebrow {
    display: block;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #6e6e73;
    margin-bottom: 0.75rem;
  }

  .s4-sp-title {
    font-size: clamp(2rem, 3.5vw, 2.75rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: #1d1d1f;
    margin: 0 0 0.75rem;
    line-height: 1.1;
  }

  .s4-sp-sub {
    font-size: 0.95rem;
    color: #86868b;
    margin: 0;
    line-height: 1.65;
  }

  .s4-sp-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    max-width: 1000px;
    margin: 0 auto;
  }

  @media (max-width: 600px) { .s4-sp-grid { grid-template-columns: 1fr; } }

  .s4-sp-card {
    background: #f5f5f7;
    border-radius: 20px;
    padding: 2.5rem 2.25rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 0;
    transition: background 0.25s ease,
                box-shadow 0.25s ease;
  }

  .s4-sp-card:hover {
    background: #fff;
    box-shadow: 0 8px 32px rgba(0,0,0,0.08);
  }

  .s4-sp-logo {
    height: 128px;
    width: auto;
    object-fit: contain;
    object-position: center;
    display: block;
    filter: grayscale(1) opacity(0.55);
    transition: filter 0.3s ease;
  }

  .s4-sp-card:hover .s4-sp-logo {
    filter: grayscale(0) opacity(1);
  }

  .s4-sp-divider {
    height: 1px;
    background: rgba(0,0,0,0.07);
    margin: 1.5rem 0 1.25rem;
  }

  .s4-sp-label {
    font-size: 0.85rem;
    font-weight: 600;
    color: #1d1d1f;
    letter-spacing: -0.01em;
    margin: 0 0 0.4rem;
  }

  .s4-sp-desc {
    font-size: 0.83rem;
    color: #86868b;
    line-height: 1.65;
    margin: 0;
  }
</style>

<div class="s4">

  <!-- ── BENTO APPLETS ──────────────────────────────────────── -->
  <section class="s4-applets">
    <div class="s4-applets-header">
      <span class="eyebrow">Extend your desktop experience</span>
      <h2>Small, but useful.</h2>
      <p>Ubuntu Budgie comes with various applets that extend the features of Budgie desktop. More are available from Budgie Welcome.</p>
    </div>

    <div class="s4-bento">
      <div class="s4-bc s4-bc-3">
        <img class="s4-bc-img" src="screens/dropby.jpg" alt="Drop By" />
        <div class="s4-bc-body">
          <h3>Drop By</h3>
          <p>Get to your files faster without opening Nemo — browse disks and locations from the panel.</p>
        </div>
      </div>

      <div class="s4-bc s4-bc-3">
        <img class="s4-bc-img" src="screens/autoswitch.png" alt="Auto-Switcher" />
        <div class="s4-bc-body">
          <h3>Auto-Switcher</h3>
          <p>Switch languages easily for each app and desktop, for those that use bilingual keyboards.</p>
        </div>
      </div>

      <div class="s4-bc s4-bc-2">
        <img class="s4-bc-img" src="screens/stopwatch.png" alt="Workspaces" />
        <div class="s4-bc-body">
          <h3>Workspaces</h3>
          <p>Control different workspaces and name each individually from the taskbar.</p>
        </div>
      </div>

      <div class="s4-bc s4-bc-2">
        <img class="s4-bc-img" src="screens/quicknote.jpg" alt="Quick Note" />
        <div class="s4-bc-body">
          <h3>Quick Note</h3>
          <p>Copy &amp; Paste or write quick notes that you want to get reminded about later.</p>
        </div>
      </div>

      <div class="s4-bc s4-bc-2">
        <img class="s4-bc-img" src="screens/visualspace.jpg" alt="Activities Overview" />
        <div class="s4-bc-body">
          <h3>Activities Overview</h3>
          <p>Check what is happening on other desktops without switching away.</p>
        </div>
      </div>

      <div class="s4-bc s4-bc-4">
        <img class="s4-bc-img" src="screens/dim.png" alt="Brightness & Backlight" style="object-position: center top;" />
        <div class="s4-bc-body">
          <h3>Brightness &amp; Backlight controller</h3>
          <p>Easily control your screen brightness and keyboard backlight from your taskbar.</p>
        </div>
      </div>
    </div>

    <div class="s4-applets-cta">
      <a href="#">Learn More</a>
    </div>
  </section>

  <!-- ── GALLERY ───────────────────────────────────────────── -->
  <div class="bg-gray-900 py-16 px-4">
    <h2 class="text-3xl md:text-4xl font-bold text-white text-center mb-10">Make it your own</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4 max-w-7x2 mx-auto">
      <img src="screens/sc1.jpeg"  alt="Screenshot 1"  class="w-full h-auto rounded-lg shadow-lg">
