      <img src="screens/sc4.jpeg"  alt="Screenshot 4"  class="w-full h-auto rounded-lg shadow-lg">
      <img src="screens/sc5.jpeg"  alt="Screenshot 5"  class="w-full h-auto rounded-lg shadow-lg">
