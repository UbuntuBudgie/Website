<style>
  .s2-wrap {
    background: #f5f5f7;
    padding: 4rem 1.5rem 5rem;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Ubuntu, Cantarell, sans-serif;
  }

  .s2-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    max-width: 1650px;
    margin: 0 auto;
  }

  @media (max-width: 860px) {
    .s2-grid { grid-template-columns: 1fr; max-width: 480px; }
  }

  /* ── Card ── */
  .s2-card {
    background: #ffffff;
    border-radius: 20px;
    padding: 2.25rem 2rem 2rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
    transition: transform 0.3s cubic-bezier(0.22,1,0.36,1),
                box-shadow 0.3s cubic-bezier(0.22,1,0.36,1);
  }

  .s2-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.09);
  }

  /* ── Icon ── */
  .s2-icon {
    width: 64px;
    height: 64px;
    margin-bottom: 1.4rem;
    object-fit: contain;
   
  }

  /* ── Heading ── */
  .s2-card h3 {
    font-size: 1.15rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #1d1d1f;
    line-height: 1.25;
    margin: 0 0 0.65rem;
  }

  /* ── Body ── */
  .s2-card p {
    font-size: 0.9rem;
    color: #6e6e73;
    line-height: 1.65;
    margin: 0 0 1.4rem;
    flex-grow: 1;
  }

  /* ── Learn more link ── */
  .s2-link {
    font-size: 0.88rem;
    font-weight: 500;
    color: #0071e3;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
    transition: gap 0.2s ease;
    margin-top: auto;
  }

  .s2-link:hover { gap: 0.4rem; }

  .s2-link .arr {
    display: inline-block;
    transition: transform 0.2s ease;
  }

  .s2-link:hover .arr { transform: translateX(3px); }

  /* ── Fade-in ── */
  @keyframes s2FadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .s2-card:nth-child(1) { animation: s2FadeUp 0.6s cubic-bezier(0.22,1,0.36,1) 0.05s both; }
  .s2-card:nth-child(2) { animation: s2FadeUp 0.6s cubic-bezier(0.22,1,0.36,1) 0.15s both; }
  .s2-card:nth-child(3) { animation: s2FadeUp 0.6s cubic-bezier(0.22,1,0.36,1) 0.25s both; }
</style>

<section class="s2-wrap">
  <div class="s2-grid">

    <!-- Card 1 — Responsive -->
    <div class="s2-card">
      <img class="s2-icon" src="/icons/input-keyboard.svg" alt="" aria-hidden="true" />
      <h3>Responsive by design.</h3>
      <p>Friendly to newcomers from other Operating Systems, programmers and everyday users alike.</p>
      <a href="/about" class="s2-link">Learn more <span class="arr" aria-hidden="true">›</span></a>
    </div>

    <!-- Card 2 — Updated -->
    <div class="s2-card">
      <img class="s2-icon" src="/icons/system-software-update.svg" alt="" aria-hidden="true" />
      <h3>Always up to date.</h3>
      <p>Easy to update and maintain. Update to the next release or wait for a big upgrade — the choice is always yours.</p>
      <a href="/downloads" class="s2-link">Learn more <span class="arr" aria-hidden="true">›</span></a>
    </div>

    <!-- Card 3 — Powerful -->
    <div class="s2-card">
      <img class="s2-icon" src="/icons/cpu.svg" alt="" aria-hidden="true" />
      <h3>Powerful performance.</h3>
      <p>Customizable and optimized for performance on both the desktop and laptop — no compromises.</p>
      <a href="/about" class="s2-link">Learn more <span class="arr" aria-hidden="true">›</span></a>
    </div>

  </div>
</section>