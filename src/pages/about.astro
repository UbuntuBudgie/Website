---
import BaseLayout from "../layouts/BaseLayout.astro";
import Faq from "../components/infopages/Faq.astro";
const pageTitle = "About Us";
---

<style>
  :root {
    --apple-bg: #f5f5f7;
    --apple-white: #ffffff;
    --apple-ink: #1d1d1f;
    --apple-secondary: #6e6e73;
    --apple-tertiary: #86868b;
    --apple-blue: #0071e3;
    --apple-blue-hover: #0077ed;
    --apple-border: rgba(0,0,0,0.08);
    --section-padding: clamp(5rem, 10vw, 9rem);
  }

  * { box-sizing: border-box; }

  .about-page {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
    color: var(--apple-ink);
    background: var(--apple-white);
    overflow-x: hidden;
  }

  /* ── HERO ─────────────────────────────────────────────────── */
  .hero {
    background: var(--apple-white);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 6rem 1.5rem;
    text-align: center;
  }

  .hero-eyebrow {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--apple-blue);
    margin-bottom: 1.25rem;
  }

  .hero h1 {
    font-size: clamp(2rem, 4.5vw, 3.75rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.08;
    color: var(--apple-ink);
    max-width: 820px;
    margin: 0 auto 2rem;
  }

  .hero-body {
    max-width: 1200px;
    margin: 0 auto;
    color: var(--apple-secondary);
    font-size: clamp(1rem, 1.8vw, 1.175rem);
    line-height: 1.75;
    font-weight: 400;
  }

  .hero-body p + p { margin-top: 1.25rem; }

  .hero-body a {
    color: var(--apple-blue);
    text-decoration: none;
    font-weight: 500;
  }

  .hero-body a:hover { text-decoration: underline; }

  .hero-tagline {
    margin-top: 2rem;
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--apple-ink);
    letter-spacing: -0.01em;
  }

  /* ── APPS GRID ─────────────────────────────────────────────── */
  .apps-section {
    background: var(--apple-bg);
    padding: var(--section-padding) 1.5rem;
  }

  .section-label {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-label h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--apple-ink);
    margin: 0;
  }

  .section-label p {
    color: var(--apple-secondary);
    font-size: 1.05rem;
    margin-top: 0.75rem;
  }

  .apps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.25rem;
    max-width: 1080px;
    margin: 0 auto;
  }

  .app-card {
    background: var(--apple-white);
    border-radius: 20px;
    border: 1px solid var(--apple-border);
    padding: 2.25rem 1.75rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    text-align: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    cursor: pointer;
  }

  .app-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 48px rgba(0,0,0,0.10);
  }

  .app-card img {
    width: 56px;
    height: 56px;
    object-fit: contain;
  }

  .app-card h3 {
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--apple-ink);
    margin: 0;
  }

  .app-card p {
    font-size: 0.875rem;
    color: var(--apple-secondary);
    line-height: 1.6;
    margin: 0;
  }

  /* ── FEATURE ROWS ──────────────────────────────────────────── */
  .feature-section {
    padding: var(--section-padding) 1.5rem;
  }

  .feature-section.alt {
    background: var(--apple-bg);
  }

  .feature-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(3rem, 6vw, 7rem);
    align-items: center;
    max-width: 1120px;
    margin: 0 auto;
  }

  @media (max-width: 860px) {
    .feature-row {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .feature-row.reverse > .feature-text { order: -1; }
  }

  .feature-text {}

  .feature-eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--apple-blue);
    display: block;
    margin-bottom: 0.85rem;
  }

  .feature-text h2 {
    font-size: clamp(2.25rem, 4vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.08;
    color: var(--apple-ink);
    margin: 0 0 1.5rem;
  }

  .feature-text p {
    font-size: clamp(1rem, 1.5vw, 1.1rem);
    color: var(--apple-secondary);
    line-height: 1.8;
    margin: 0;
  }

  .feature-image img {
    width: 100%;
    border-radius: 20px;
    box-shadow: 0 24px 64px rgba(0,0,0,0.12);
    display: block;
  }

  .feature-image.plain img {
    box-shadow: none;
    border-radius: 16px;
  }

  /* ── DIVIDER ───────────────────────────────────────────────── */
  .divider {
    height: 1px;
    background: var(--apple-border);
    max-width: 1080px;
    margin: 0 auto;
  }

  /* ── CTA ───────────────────────────────────────────────────── */
  .cta-section {
    background: var(--apple-bg);
    padding: clamp(4rem, 8vw, 7rem) 1.5rem;
    text-align: center;
  }

  .cta-section h2 {
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--apple-ink);
    margin: 0 0 2rem;
  }

  .cta-btn {
    display: inline-block;
    background: var(--apple-blue);
    color: #fff;
    font-family: inherit;
    font-size: 1rem;
    font-weight: 600;
    padding: 0.875rem 2.25rem;
    border-radius: 980px;
    text-decoration: none;
    letter-spacing: -0.01em;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .cta-btn:hover {
    background: var(--apple-blue-hover);
    transform: scale(1.02);
  }

  /* ── FADE-IN ANIMATIONS ────────────────────────────────────── */
  .fade-up {
    opacity: 0;
    transform: translateY(28px);
    animation: fadeUp 0.7s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  .delay-1 { animation-delay: 0.1s; }
  .delay-2 { animation-delay: 0.22s; }
  .delay-3 { animation-delay: 0.34s; }
  .delay-4 { animation-delay: 0.46s; }

  @keyframes fadeUp {
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<BaseLayout title={pageTitle}>
<div class="about-page">

  <!-- ── HERO ───────────────────────────────────────────────── -->
  <section class="hero">
    <span class="hero-eyebrow fade-up">Built For The Future</span>
    <h1 class="fade-up delay-1">
      What's <span>Ubuntu Budgie</span>?
    </h1>
    <div class="hero-body fade-up delay-2">
      <p>
        Ubuntu Budgie is a proud official member of the Ubuntu family. We combine
        the simplicity and elegance of the Budgie interface to produce a traditional
        desktop orientated distro with a modern paradigm. Budgie is a desktop
        environment focused on having a clean and yet powerful desktop without
        unnecessary bloat. To learn more, visit the
        <a href="#">Budgie Website</a>.
      </p>
      <p>
        Fully functional out of the box, we include the best available Linux
        applications that makes you productive immediately. Backed by the powerful
        Debian-derived Ubuntu repositories, customisation is just a 'point &amp;
        click' away.
      </p>
      <p class="hero-tagline">Ready to take the challenge?</p>
    </div>
  </section>

  <!-- ── APPS GRID ─────────────────────────────────────────── -->
  <section class="apps-section">
    <div class="section-label fade-up">
      <h2>This is why you'll love Ubuntu Budgie</h2>
      <p>Everything you need, included from day one.</p>
    </div>

    <div class="apps-grid">
      <div class="app-card fade-up delay-1">
        <img src="/icons/firefox.png" alt="Firefox" />
        <h3>Firefox</h3>
        <p>Safe &amp; easy web browser that protects your privacy.</p>
      </div>
      <div class="app-card fade-up delay-2">
        <img src="/icons/rhythmbox-icon.png" alt="Rhythmbox" />
        <h3>Rhythmbox</h3>
        <p>Music player &amp; organiser.</p>
      </div>
      <div class="app-card fade-up delay-3">
        <img src="/icons/thunderbird.svg" alt="Thunderbird" />
        <h3>Thunderbird</h3>
        <p>Email app that's easy to set up &amp; customise — packed with features!</p>
      </div>
      <div class="app-card fade-up delay-1">
        <img src="/icons/libreoffice.svg" alt="LibreOffice" />
        <h3>LibreOffice</h3>
        <p>Full-featured office suite with Microsoft Office compatibility.</p>
      </div>
      <div class="app-card fade-up delay-2">
        <img src="/icons/ubwc.svg" alt="Budgie Welcome Center" />
        <h3>Budgie Welcome Center</h3>
        <p>Learn and control your OS from the moment you log in.</p>
      </div>
      <div class="app-card fade-up delay-3">
        <img src="/icons/celluloid.svg" alt="Celluloid" />
        <h3>Celluloid</h3>
        <p>Free, open source &amp; cross-platform media player.</p>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- ── FEATURE 1: Pre-Configured ────────────────────────── -->
  <section class="feature-section">
    <div class="feature-row">
      <div class="feature-image plain fade-up">
        <img src="/screens/ubw.png" alt="Ubuntu Budgie pre-configured desktop" />
      </div>
      <div class="feature-text fade-up delay-2">
        <span class="feature-eyebrow">Ready on arrival</span>
        <h2>Pre-Configured</h2>
        <p>
          Ubuntu Budgie includes carefully curated default applications and
          beautiful Budgie applets. It is ready to go right out of the box —
          no setup headaches, no missing pieces.
        </p>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- ── FEATURE 2: Security ──────────────────────────────── -->
  <section class="feature-section alt">
    <div class="feature-row reverse">
      <div class="feature-text fade-up">
        <span class="feature-eyebrow">Always protected</span>
        <h2>Built-in Security</h2>
        <p>
          Security is taken seriously. Ubuntu's built-in security features —
          automatic updates and AppArmor profiles — keep you protected around
          the clock, quietly working in the background.
        </p>
      </div>
      <div class="feature-image fade-up delay-2">
        <img
          src="/screens/sec.png"
          alt="Ubuntu Budgie security features"
        />
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- ── FEATURE 3: Powerful Apps ─────────────────────────── -->
  <section class="feature-section">
    <div class="feature-row">
      <div class="feature-image fade-up">
        <img
          src="/screens/budgie-desktop-settings.jpg"
          alt="Budgie Desktop Settings"
        />
      </div>
      <div class="feature-text fade-up delay-2">
        <span class="feature-eyebrow">Your workstation, elevated</span>
        <h2>Powerful Applications</h2>
        <p>
          While Budgie Desktop provides the essential interface, Ubuntu Budgie
          adds a curated collection of applications — from productivity to
          entertainment — turning your machine into a truly capable workstation.
        </p>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- ── FEATURE 4: Gaming ────────────────────────────────── -->
  <section class="feature-section alt">
    <div class="feature-row reverse">
      <div class="feature-text fade-up">
        <span class="feature-eyebrow">Play without limits</span>
        <h2>Gaming</h2>
        <p>
          Linux has become a first-class gaming platform. Steam alone offers
          over 2,000 indie and AAA titles ready for Ubuntu Budgie — plus a
          rich library of high-quality open source games covering every genre
          imaginable.
        </p>
      </div>
      <div class="feature-image fade-up delay-2">
        <img
          src="/screens/steam.jpg"
          alt="Steam on Ubuntu Budgie"
        />
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- ── FEATURE 5: Easy Migrations ───────────────────────── -->
  <section class="feature-section">
    <div class="feature-row">
      <div class="feature-image fade-up">
        <img
          src="/screens/appmenu.jpg"
          alt="Ubuntu Budgie App Menu"
        />
      </div>
      <div class="feature-text fade-up delay-2">
        <span class="feature-eyebrow">You'll feel quite at home</span>
        <h2>Easy Migrations</h2>
        <p>
          Connect your accounts, sync your calendars and download your
          favourite apps. Ubuntu Budgie adapts to the way you work — making
          switching platforms feel effortless.
        </p>
      </div>
    </div>
  </section>

  <!-- ── CTA ───────────────────────────────────────────────── -->
  <section class="cta-section">
    <h2 class="fade-up">Ready to experience Ubuntu Budgie?</h2>
    <a href="/download" class="cta-btn fade-up delay-1">
      Download Ubuntu Budgie
    </a>
  </section>

</div>
</BaseLayout>